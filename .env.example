# ── MediaEncoder agent ────────────────────────────────────────────────────────

# URL publique du serveur (accessible depuis cet hôte).
# Si le serveur est intégré dans manage-nas, ajouter le préfixe /encoder.
# Exemple standalone : http://192.168.1.2:5400
# Exemple manage-nas : https://manage.nfour.fr/encoder
SERVER_URL=http://192.168.1.2:5400

# Clé API de l'agent (générée dans l'interface Agents du serveur)
API_KEY=change-me

# Basic Auth pour traverser un reverse proxy (format user:pass). Optionnel.
# BASIC_AUTH=user:password

# Intervalle de sondage en secondes (défaut : 5)
# POLL_INTERVAL=5

# Identifiant de l'agent côté serveur (défaut : hostname du conteneur)
# AGENT_ID=pc-gamer

# Chemin hôte de stockage des fichiers temporaires
WORK_PATH=./work
