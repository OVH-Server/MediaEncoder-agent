# ── MediaEncoder agent ────────────────────────────────────────────────────────

# Clé API partagée serveur <-> agent (doit être identique dans server/.env)
API_KEY=change-me

# Port publié sur l'hôte (le serveur contacte http://<ip-du-pc>:5401)
FLASK_PORT=5401

# Chemin hôte de stockage des fichiers à compresser / compressés
WORK_PATH=./work
